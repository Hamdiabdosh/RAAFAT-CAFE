// CaféOS — Module 1 foundation (+ core entities referenced later)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OwnerStatus {
  unverified
  active
  suspended
}

enum SubscriptionStatus {
  pending
  active
  expired
  cancelled
}

enum CafeStatus {
  open
  closed
}

enum MenuStatus {
  draft
  published
  unpublished
}

enum ItemAvailability {
  available
  sold_out
}

enum OrderStatus {
  new
  preparing
  ready
  served
  cancelled
}

enum OrderType {
  dine_in
  takeaway
}

enum StaffStatus {
  active
  suspended
}

enum BillingInterval {
  monthly
  yearly
}

// ─── Plans & admin ───────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(50)
  slug         String   @unique @db.VarChar(20)
  price        Decimal  @db.Decimal(10, 2)
  priceYearly  Decimal? @map("price_yearly") @db.Decimal(10, 2)
  entitlements Json     @default("{}")
  features     Json     @default("[]")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  activatedSubscriptions Subscription[] @relation("ActivatedByAdmin")
  impersonationLogs    ImpersonationLog[]

  @@map("admin_users")
}

// ─── Owners & subscriptions ──────────────────────────────────────────────────

model CafeOwner {
  id                    String      @id @default(uuid()) @db.Uuid
  email                 String      @unique @db.VarChar(255)
  passwordHash          String      @map("password_hash") @db.VarChar(255)
  fullName              String      @map("full_name") @db.VarChar(100)
  emailVerified         Boolean     @default(false) @map("email_verified")
  verifyToken           String?     @map("verify_token") @db.VarChar(255)
  verifyTokenExpiresAt  DateTime?   @map("verify_token_expires_at")
  resetToken            String?     @map("reset_token") @db.VarChar(255)
  resetTokenExpiresAt   DateTime?   @map("reset_token_expires_at")
  status                   OwnerStatus      @default(unverified)
  selectedPlanSlug         String?          @map("selected_plan_slug") @db.VarChar(20)
  selectedBillingInterval  BillingInterval? @map("selected_billing_interval")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  subscription Subscription?
  cafe         Cafe?

  @@map("cafe_owners")
}

model Subscription {
  id           String             @id @default(uuid()) @db.Uuid
  cafeOwnerId  String             @unique @map("cafe_owner_id") @db.Uuid
  planId       String             @map("plan_id") @db.Uuid
  status       SubscriptionStatus @default(pending)
  startsAt     DateTime?          @map("starts_at")
  expiresAt    DateTime?          @map("expires_at")
  activatedBy  String?            @map("activated_by") @db.Uuid
  notes        String?            @db.Text
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  cafeOwner CafeOwner  @relation(fields: [cafeOwnerId], references: [id], onDelete: Cascade)
  plan      Plan       @relation(fields: [planId], references: [id])
  activator AdminUser? @relation("ActivatedByAdmin", fields: [activatedBy], references: [id])

  @@index([status])
  @@map("subscriptions")
}

// ─── Café ────────────────────────────────────────────────────────────────────

model Cafe {
  id              String     @id @default(uuid()) @db.Uuid
  ownerId         String     @unique @map("owner_id") @db.Uuid
  name            String     @db.VarChar(60)
  slug            String     @unique @db.VarChar(80)
  description     String?    @db.VarChar(200)
  address         String?    @db.VarChar(120)
  phone           String?    @db.VarChar(30)
  logoUrl         String?    @map("logo_url") @db.VarChar(500)
  primaryColor    String     @default("#000000") @map("primary_color") @db.VarChar(7)
  bgColor         String     @default("#ffffff") @map("bg_color") @db.VarChar(7)
  status          CafeStatus @default(closed)
  profileComplete Boolean    @default(false) @map("profile_complete")
  timezone        String     @default("UTC") @db.VarChar(64)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  owner           CafeOwner        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  operatingHours  OperatingHour[]
  staff           CafeStaff[]
  menu            Menu?
  orders          Order[]
  impersonationLogs ImpersonationLog[]

  @@map("cafes")
}

model OperatingHour {
  id        String   @id @default(uuid()) @db.Uuid
  cafeId    String   @map("cafe_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week") @db.SmallInt
  isClosed  Boolean  @default(false) @map("is_closed")
  openTime  DateTime? @map("open_time") @db.Time
  closeTime DateTime? @map("close_time") @db.Time
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([cafeId, dayOfWeek])
  @@map("operating_hours")
}

model CafeStaff {
  id           String      @id @default(uuid()) @db.Uuid
  cafeId       String      @map("cafe_id") @db.Uuid
  email        String      @db.VarChar(255)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  fullName     String      @map("full_name") @db.VarChar(100)
  status       StaffStatus @default(active)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([cafeId, email])
  @@map("cafe_staff")
}

// ─── Menu (schema ready for Module 3) ────────────────────────────────────────

model Menu {
  id          String     @id @default(uuid()) @db.Uuid
  cafeId      String     @unique @map("cafe_id") @db.Uuid
  status      MenuStatus @default(draft)
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  cafe       Cafe       @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  categories Category[]

  @@map("menus")
}

model DietaryTag {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(30)

  items ItemDietaryTag[]

  @@map("dietary_tags")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  menuId    String    @map("menu_id") @db.Uuid
  cafeId    String    @map("cafe_id") @db.Uuid
  name      String    @db.VarChar(50)
  sortOrder Int       @default(0) @map("sort_order") @db.SmallInt
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  menu  Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items Item[]

  @@index([menuId, sortOrder])
  @@map("categories")
}

model Item {
  id           String           @id @default(uuid()) @db.Uuid
  categoryId   String           @map("category_id") @db.Uuid
  cafeId       String           @map("cafe_id") @db.Uuid
  name         String           @db.VarChar(80)
  description  String?          @db.VarChar(300)
  basePrice    Decimal          @map("base_price") @db.Decimal(10, 2)
  photoUrl     String?          @map("photo_url") @db.VarChar(500)
  availability ItemAvailability @default(available)
  sortOrder    Int              @default(0) @map("sort_order") @db.SmallInt
  deletedAt    DateTime?        @map("deleted_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  category       Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  dietaryTags    ItemDietaryTag[]
  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]

  @@index([categoryId, sortOrder])
  @@index([cafeId, availability])
  @@map("items")
}

model ItemDietaryTag {
  itemId String @map("item_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  item Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  DietaryTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@map("item_dietary_tags")
}

model ModifierGroup {
  id         String    @id @default(uuid()) @db.Uuid
  itemId     String    @map("item_id") @db.Uuid
  cafeId     String    @map("cafe_id") @db.Uuid
  name       String    @db.VarChar(50)
  isRequired Boolean   @default(false) @map("is_required")
  isMulti    Boolean   @default(false) @map("is_multi")
  sortOrder  Int       @default(0) @map("sort_order") @db.SmallInt
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  item    Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id        String    @id @default(uuid()) @db.Uuid
  groupId   String    @map("group_id") @db.Uuid
  name      String    @db.VarChar(50)
  priceAdj  Decimal   @default(0) @map("price_adj") @db.Decimal(10, 2)
  sortOrder Int       @default(0) @map("sort_order") @db.SmallInt
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("modifier_options")
}

// ─── Orders (schema ready for Module 4–5) ────────────────────────────────────

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  cafeId       String      @map("cafe_id") @db.Uuid
  orderToken   String      @unique @map("order_token") @db.Uuid
  dailyNumber  Int         @map("daily_number") @db.SmallInt
  orderDate    DateTime    @map("order_date") @db.Date
  type         OrderType
  tableNumber  Int?        @map("table_number") @db.SmallInt
  note         String?     @db.VarChar(200)
  status       OrderStatus @default(new)
  totalAmount  Decimal     @map("total_amount") @db.Decimal(10, 2)
  cancelReason String?     @map("cancel_reason") @db.VarChar(200)
  cancelledBy  String?     @map("cancelled_by") @db.Uuid
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  cafe  Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@unique([cafeId, dailyNumber, orderDate])
  @@index([cafeId, createdAt])
  @@index([orderToken])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  itemId    String?  @map("item_id") @db.Uuid
  itemName  String   @map("item_name") @db.VarChar(80)
  basePrice Decimal  @map("base_price") @db.Decimal(10, 2)
  quantity  Int      @db.SmallInt
  subtotal  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order     Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item      Item?                @relation(fields: [itemId], references: [id], onDelete: SetNull)
  modifiers OrderItemModifier[]

  @@map("order_items")
}

model OrderItemModifier {
  id          String   @id @default(uuid()) @db.Uuid
  orderItemId String   @map("order_item_id") @db.Uuid
  groupName   String   @map("group_name") @db.VarChar(50)
  optionName  String   @map("option_name") @db.VarChar(50)
  priceAdj    Decimal  @map("price_adj") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_modifiers")
}

model ImpersonationLog {
  id        String    @id @default(uuid()) @db.Uuid
  adminId   String    @map("admin_id") @db.Uuid
  cafeId    String    @map("cafe_id") @db.Uuid
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  cafe  Cafe      @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("impersonation_logs")
}
