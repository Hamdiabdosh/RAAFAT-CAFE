DATABASE_URL="postgresql://cafeos:cafeos@localhost:5433/cafeos?schema=public"

PORT=3001
NODE_ENV=development

# Comma-separated origins for CORS (include your Vite dev URL)
CORS_ORIGIN="http://localhost:5173,http://localhost:8080,http://localhost:3000"

JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
JWT_ADMIN_EXPIRES_IN="7d"

# Super admin seed (override in production)
ADMIN_EMAIL="admin@cafeos.local"
ADMIN_PASSWORD="ChangeMeAdmin123"

# Public URL of the web app (used in verification/reset email links)
WEB_APP_URL="http://localhost:8080"

# Email — leave empty to log links to console in development
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="CaféOS <noreply@cafeos.local>"
